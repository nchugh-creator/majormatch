# Copy this to .env and fill in your values

# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/majormatch?sslmode=require

# Secret for signing JWT tokens — generate with: openssl rand -hex 32
JWT_SECRET=your_super_secret_key_here

# Environment
NODE_ENV=production

# Optional: restrict CORS to your domain
CLIENT_ORIGIN=https://majormatch-two.vercel.app
